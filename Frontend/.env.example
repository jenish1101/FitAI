# FitAI — copy to .env and adjust per environment
# Only EXPO_PUBLIC_* variables are available in the client bundle

# Use mock data offline (true) or connect to Fitness-Backend (false)
EXPO_PUBLIC_ENABLE_MOCK_API=false

# Backend API — start Fitness-Backend first (default PORT=8001 in backend .env)
# Web / iOS simulator: http://localhost:8001/v1
# Android emulator:     http://10.0.2.2:8001/v1
# Physical device:      http://<your-lan-ip>:8001/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8001/v1

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=FitAI
EXPO_PUBLIC_API_TIMEOUT_MS=15000
