# Application
APP_NAME=FitAI API
APP_ENV=development
API_V1_PREFIX=/v1
DEBUG=true

# Server
HOST=0.0.0.0
# Default 8001 — Portainer/Docker often occupies 8000
PORT=8001

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=fitai

# Security
# Minimum 16 characters (enforced by Pydantic Settings)
SECRET_KEY=change-me-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma-separated origins for Expo / web dev)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006

# Seed
SEED_REFERENCE_DATA=true
SEED_DEMO_USER=true
DEMO_USER_EMAIL=demo@fitai.app
DEMO_USER_PASSWORD=demo1234
